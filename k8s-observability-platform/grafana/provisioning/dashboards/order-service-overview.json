{
  "title": "Order Service Overview",
  "timezone": "browser",
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(order_service_requests_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(order_service_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(order_service_requests_total[5m]))",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "p50 / p95 / p99 Latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(order_service_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(order_service_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(order_service_request_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "In-Progress Requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "order_service_in_progress_requests",
          "legendFormat": "in-flight"
        }
      ]
    },
    {
      "id": 5,
      "title": "Orders Created vs Failed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(order_service_orders_created_total[1m]))",
          "legendFormat": "created/s"
        },
        {
          "expr": "sum(rate(order_service_order_failures_total[1m])) by (reason)",
          "legendFormat": "failed: {{reason}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
